{
  "name": "sazabot-template",
  "version": "1.0.0",
  "description": "WhatsApp bot with plugin system & Meta AI-style rich response",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:bun": "bun --smol index.js",
    "start:bun:no-smol": "bun index.js",
    "start:dev": "bun --watch index.js",
    "start:node": "node index.js",
    "build": "npm run rebuild",
    "rebuild": "node -e \"try{require('better-sqlite3')}catch(e){}\" && npm rebuild better-sqlite3 sharp --build-from-source",
    "postinstall": "npm rebuild better-sqlite3 sharp --build-from-source"
  },
  "dependencies": {
    "baileys": "^7.0.0-rc.9",
    "pino": "^9.0.0",
    "qrcode-terminal": "^0.12.0",
    "chokidar": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "sharp": "^0.33.0",
    "chalk": "^5.4.1"
  },
  "license": "MIT"
}
